#!/usr/bin/env bash
# bmo-context-reseed: One-command context reseed

set -euo pipefail

HOST_CONTEXT_DIR="$HOME/bmo-context"
REPO_CONTEXT_DIR="$HOME/.openclaw/workspace/bmo-stack/context"

echo "=== BMO Context Reseed ==="
echo "Syncing from host context to repo context..."

# Ensure repo context exists
if [ ! -d "$REPO_CONTEXT_DIR" ]; then
    echo "Error: Repo context directory not found: $REPO_CONTEXT_DIR"
    exit 1
fi

# Sync from host to repo
rsync -av --delete "$HOST_CONTEXT_DIR/" "$REPO_CONTEXT_DIR/"
echo "Done."

echo "=== End Reseed ==="