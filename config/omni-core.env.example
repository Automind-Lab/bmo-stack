# Omni Core Configuration for Local-First Operation
# Copy this to ~/.config/omni-core.env and customize

# Local Model Settings (no external API needed)
OMNI_ENABLE_LOCAL=true
OMNI_LOCAL_MODEL=omni-core:phase2
OMNI_LOCAL_BASE_URL=http://127.0.0.1:8799/api/omni

# External Provider Settings (optional - enable as needed)
OMNI_OPENAI_ENABLED=false
OMNI_ANTHROPIC_ENABLED=false
OMNI_GOOGLE_ENABLED=false
OMNI_XAI_ENABLED=false

# Routing Strategy (quality|latency|cost|local-first)
OMNI_ROUTING_STRATEGY=local-first

# Fallback Chains
OMNI_FALLBACK_TO_OLLAMA=true
OMNI_OLLAMA_MODEL=gemma:2b

# Vision Settings
OMNI_VISION_ENABLED=true
OMNI_VISION_MODEL=moondream

# Audio Settings (for voice features)
OMNI_AUDIO_ENABLED=true
OMNI_TTS_MODEL=piper/en_US-lessac-medium.onnx

# Memory & Context
OMNI_CONTEXT_WINDOW=131072
OMNI_MAX_TOKENS=4096

# Storage Hygiene
OMNI_RETENTION_HOURS=24
OMNI_MAX_STORAGE_MB=4096